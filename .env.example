# Google Apps Script Web App URL — receives POST with {name, phone, timestamp}
# See HUONG_DAN_GOOGLE_SHEET.md for setup instructions
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Anthropic API key — dùng cho Trợ lý Chim Sẻ (AI chat trong bài học)
# Lấy tại: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx
